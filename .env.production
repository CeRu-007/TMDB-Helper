# 生产环境配置
NODE_ENV=production
PORT=4949

# NextAuth配置
NEXTAUTH_URL=https://your-domain.com
NEXTAUTH_SECRET=your-nextauth-secret-here

# JWT认证配置（生产环境必须配置）
JWT_SECRET=your-strong-random-jwt-secret-key-here

# 管理员账户配置
# 项目已改为“先注册后登录”模式，启动时不会自动创建管理员。
# 首次使用请在登录页注册管理员账号。

# Session配置
SESSION_EXPIRY_DAYS=15

# 数据目录配置
TMDB_DATA_DIR=./data

# Cookie Secure 配置
COOKIE_SECURE=true

# 禁用遥测
NEXT_TELEMETRY_DISABLED=1

# 优化设置
NODE_OPTIONS=--max-old-space-size=4096